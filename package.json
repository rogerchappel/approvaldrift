{
  "name": "approvaldrift",
  "version": "0.1.0",
  "description": "Local-first approval-boundary drift checker for agent action plans.",
  "type": "module",
  "exports": {
    ".": "./src/index.js"
  },
  "bin": {
    "approvaldrift": "./bin/approvaldrift.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node scripts/check.js",
    "smoke": "node bin/approvaldrift.js fixtures/transcripts/safe-plan.md fixtures/policies/default.json --format markdown"
  },
  "keywords": [
    "agents",
    "approval",
    "policy",
    "dry-run"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin",
    "src",
    "docs",
    "fixtures",
    "SKILL.md",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/approvaldrift.git"
  }
}
